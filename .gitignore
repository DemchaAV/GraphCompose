*.tmp
*.bak
*~
*.swp
*.swo

### Local-only / not for the public repo ###
# Claude Code working directory (settings, worktrees, transcripts).
.claude/
# Internal planning, audit, and roadmap notes that should not ship in the
# public docs surface. Files placed here stay on disk for the author and
# stay out of git.
docs/private/

.llm-wiki/

# Visual regression test diagnostic artifacts — produced when a parity
# test fails, useful for review locally, not part of repo state.
**/visual-baselines/**/*.actual.png
**/visual-baselines/**/*.diff.png
